{% extends 'base.html.twig' %}

{% block title %}Mes offres{% endblock %}

{% block body %}
    <h1>Mes offres</h1>
    <p><small>{{ totalItems }} résultat(s)</small></p>

    <p><a href="{{ path('offer_new') }}">Créer une offre</a></p>

    {% if offers is empty %}
        <p>Aucune offre.</p>
    {% else %}
        <ul>
            {% for offer in offers %}
                <li>
                    <a href="{{ path('offer_show', {id: offer.id}) }}">{{ offer.title }}</a>
                    - {{ offer.company.name }}
                    <span class="status-badge status-{{ offer.status|lower }}">
                        {{ pointsReasonLabelService.offerStatusLabel(offer.status) }}
                        {% if offer.status %} ({{ offer.status }}){% endif %}
                    </span>
                    <span class="status-badge status-{{ offer.moderationStatus|lower }}">
                        Modération : {{ pointsReasonLabelService.offerModerationStatusLabel(offer.moderationStatus) }}
                        {% if offer.moderationStatus %} ({{ offer.moderationStatus }}){% endif %}
                    </span>
                </li>
            {% endfor %}
        </ul>

        {% if totalPages > 1 %}
            <nav aria-label="Pagination offres recruteur">
                {% if currentPage > 1 %}
                    <a href="{{ path('recruiter_offer_index', {page: currentPage - 1}) }}">Page précédente</a>
                {% endif %}
                <span>Page {{ currentPage }} / {{ totalPages }}</span>
                {% if currentPage < totalPages %}
                    <a href="{{ path('recruiter_offer_index', {page: currentPage + 1}) }}">Page suivante</a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}
