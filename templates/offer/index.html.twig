{% extends 'base.html.twig' %}

{% block title %}Offres{% endblock %}

{% block body %}
    <h1>Offres</h1>
    <p><small>{{ totalItems }} resultat(s)</small></p>

    {% if app.user and app.user.isCompany %}
        <p><a href="{{ path('offer_new') }}">Creer une offre</a></p>
    {% endif %}

    {% if offers is empty %}
        <p>Aucune offre.</p>
    {% else %}
        <ul>
            {% for offer in offers %}
                <li>
                    <a href="{{ path('offer_show', {id: offer.id}) }}">{{ offer.title }}</a>
                    - {{ offer.company.name }}
                </li>
            {% endfor %}
        </ul>

        {% if totalPages > 1 %}
            <nav aria-label="Pagination offres">
                {% if currentPage > 1 %}
                    <a href="{{ path('offer_index', {page: currentPage - 1}) }}">Page precedente</a>
                {% endif %}
                <span>Page {{ currentPage }} / {{ totalPages }}</span>
                {% if currentPage < totalPages %}
                    <a href="{{ path('offer_index', {page: currentPage + 1}) }}">Page suivante</a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}
