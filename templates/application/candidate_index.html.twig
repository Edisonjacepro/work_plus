{% extends 'base.html.twig' %}

{% block title %}Mes candidatures{% endblock %}

{% block body %}
    <h1>Fiche candidat</h1>

    <section>
        <h2>Informations</h2>
        <p><strong>Email :</strong> {{ candidate.email }}</p>
        <p><strong>Prénom :</strong> {{ candidate.firstName ?: '-' }}</p>
        <p><strong>Nom :</strong> {{ candidate.lastName ?: '-' }}</p>
        <p><strong>Type de compte :</strong> {{ candidate.accountType }}</p>
    </section>

    <section>
        <h2>Points impact</h2>
        <p><strong>Total cumulé :</strong> {{ candidatePointsBalance }}</p>
        <p><strong>Niveau :</strong> {{ candidatePointsLevel }}</p>

        <h3>Détail des points</h3>
        {% if candidatePointsHistory is empty %}
            <p>Aucun événement de points pour le moment.</p>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Référence</th>
                        <th>Motif</th>
                        <th>Points</th>
                        <th>Détails</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in candidatePointsHistory %}
                        <tr>
                            <td>{{ entry.createdAt ? entry.createdAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>{{ entry.referenceType }}{% if entry.referenceId %} #{{ entry.referenceId }}{% endif %}</td>
                            <td>{{ entry.reason }}</td>
                            <td>{{ entry.points > 0 ? '+' ~ entry.points : entry.points }}</td>
                            <td>
                                {% if entry.metadata and entry.metadata.basePoints is defined %}
                                    base {{ entry.metadata.basePoints }}{% if entry.metadata.impactBonusPoints is defined %} + bonus {{ entry.metadata.impactBonusPoints }}{% endif %}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>

    <section>
        <h2>Mes candidatures</h2>
        <p><small>{{ totalItems }} résultat(s)</small></p>
        {% if applications is empty %}
            <p>Vous n'avez pas encore postulé.</p>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>Offre</th>
                        <th>Entreprise</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for application in applications %}
                        <tr>
                            <td>{{ application.offer.title }}</td>
                            <td>{{ application.offer.company.name }}</td>
                            <td>{{ application.createdAt ? application.createdAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>
                                <span class="status-badge status-{{ application.status|lower }}">
                                    {{ application.status == 'HIRED' ? 'Embauché' : 'Soumise' }}
                                </span>
                            </td>
                            <td><a href="{{ path('application_show', {id: application.id}) }}">Consulter</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            {% if totalPages > 1 %}
                <nav aria-label="Pagination candidatures candidat">
                    {% if currentPage > 1 %}
                        <a href="{{ path('application_candidate_index', {page: currentPage - 1}) }}">Page précédente</a>
                    {% endif %}
                    <span>Page {{ currentPage }} / {{ totalPages }}</span>
                    {% if currentPage < totalPages %}
                        <a href="{{ path('application_candidate_index', {page: currentPage + 1}) }}">Page suivante</a>
                    {% endif %}
                </nav>
            {% endif %}
        {% endif %}
    </section>
{% endblock %}
