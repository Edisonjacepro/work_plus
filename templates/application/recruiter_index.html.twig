{% extends 'base.html.twig' %}

{% block title %}Candidatures reçues{% endblock %}

{% block body %}
    <h1>Candidatures reçues</h1>
    <p><small>{{ totalItems }} résultat(s)</small></p>

    {% if applications is empty %}
        <p>Aucune candidature pour le moment.</p>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Offre</th>
                    <th>Candidat</th>
                    <th>Email</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for application in applications %}
                    <tr>
                        <td>{{ application.offer.title }}</td>
                        <td>{{ application.firstName }} {{ application.lastName }}</td>
                        <td>{{ application.email }}</td>
                        <td>{{ application.createdAt ? application.createdAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>
                            <span class="status-badge status-{{ application.status|lower }}">
                                {{ application.status == 'HIRED' ? 'Embauché' : 'Soumise' }}
                            </span>
                        </td>
                        <td><a href="{{ path('application_show', {id: application.id}) }}">Consulter</a></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% if totalPages > 1 %}
            <nav aria-label="Pagination candidatures recruteur">
                {% if currentPage > 1 %}
                    <a href="{{ path('application_recruiter_index', {page: currentPage - 1}) }}">Page précédente</a>
                {% endif %}
                <span>Page {{ currentPage }} / {{ totalPages }}</span>
                {% if currentPage < totalPages %}
                    <a href="{{ path('application_recruiter_index', {page: currentPage + 1}) }}">Page suivante</a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}
