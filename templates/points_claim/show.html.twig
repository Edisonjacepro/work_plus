{% extends 'base.html.twig' %}

{% block title %}Demande de points #{{ claim.id }}{% endblock %}

{% block body %}
    <h1>Demande de points #{{ claim.id }}</h1>

    <p><strong>Entreprise :</strong> {{ claim.company.name }}</p>
    <p><strong>Type :</strong> {{ claim.claimType }}</p>
    <p><strong>Points proposés :</strong> {{ claim.requestedPoints }}</p>
    <p><strong>Points approuvés :</strong> {{ claim.approvedPoints ?? '-' }}</p>
    <p><strong>Statut :</strong> {{ claim.status }}</p>
    <p><strong>Date preuve :</strong> {{ claim.evidenceIssuedAt ? claim.evidenceIssuedAt|date('d/m/Y') : '-' }}</p>
    <p><strong>Score justificatifs :</strong> {{ claim.evidenceScore }}</p>
    <p>
        <strong>Motif (code) :</strong>
        {{ pointsReasonLabelService.pointsClaimReasonLabel(claim.decisionReasonCode) }}
        {% if claim.decisionReasonCode %} ({{ claim.decisionReasonCode }}){% endif %}
    </p>
    <p><strong>Motif décision :</strong> {{ claim.decisionReason ?: '-' }}</p>
    <p><strong>Date création :</strong> {{ claim.createdAt ? claim.createdAt|date('d/m/Y H:i') : '-' }}</p>
    <p><strong>Date revue :</strong> {{ claim.reviewedAt ? claim.reviewedAt|date('d/m/Y H:i') : '-' }}</p>

    {% set coherence = claim.externalChecks and claim.externalChecks.coherence is defined and claim.externalChecks.coherence ? claim.externalChecks.coherence : null %}
    {% if coherence %}
        {% set coherenceCriteria = coherence.criteria ?? {} %}
        <section>
            <h2>Cohérence des preuves</h2>
            <p><strong>Statut :</strong> {{ coherence.isCoherent ? 'VALIDÉE' : 'NON VALIDÉE' }}</p>
            <table>
                <thead>
                    <tr>
                        <th>Critère</th>
                        <th>Résultat</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Profil entreprise complet (site, ville, secteur)</td>
                        <td>{{ coherenceCriteria.profile_complete ?? false ? 'OK' : 'KO' }}</td>
                    </tr>
                    <tr>
                        <td>Offre cohérente (si offre liée, elle appartient à l'entreprise)</td>
                        <td>{{ coherenceCriteria.offer_consistency ?? false ? 'OK' : 'KO' }}</td>
                    </tr>
                    <tr>
                        <td>Date de preuve valide (non future, <= 24 mois)</td>
                        <td>{{ coherenceCriteria.evidence_date_valid ?? false ? 'OK' : 'KO' }}</td>
                    </tr>
                    <tr>
                        <td>Au moins 2 justificatifs exploitables</td>
                        <td>{{ coherenceCriteria.supporting_documents_minimum ?? false ? 'OK' : 'KO' }}</td>
                    </tr>
                </tbody>
            </table>
        </section>
    {% endif %}

    <section>
        <h2>Justificatifs</h2>
        {% if claim.evidenceDocuments is empty %}
            <p>Aucun justificatif.</p>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Type</th>
                        <th>Taille</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for document in claim.evidenceDocuments %}
                        <tr>
                            <td>{{ loop.index0 }}</td>
                            <td>{{ document.originalName ?? '-' }}</td>
                            <td>{{ document.mimeType ?? '-' }}</td>
                            <td>{{ document.size ?? 0 }} o</td>
                            <td><a href="{{ path('points_claim_evidence_download', {id: claim.id, index: loop.index0}) }}">Télécharger</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>

    <section>
        <h2>Audit des décisions</h2>
        {% if events is empty %}
            <p>Aucun événement de revue pour le moment.</p>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Action</th>
                        <th>Code motif</th>
                        <th>Note</th>
                        <th>Auteur</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event in events %}
                        <tr>
                            <td>{{ event.createdAt ? event.createdAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>
                                {{ pointsReasonLabelService.pointsClaimReviewActionLabel(event.action) }}
                                {% if event.action %} ({{ event.action }}){% endif %}
                            </td>
                            <td>
                                {{ pointsReasonLabelService.pointsClaimReasonLabel(event.reasonCode) }}
                                {% if event.reasonCode %} ({{ event.reasonCode }}){% endif %}
                            </td>
                            <td>{{ event.reasonText ?: '-' }}</td>
                            <td>{{ event.actor ? event.actor.email : 'SYSTEM' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>

    <p>
        <a href="{{ path('points_claim_index') }}">Retour aux demandes</a>
    </p>
{% endblock %}
